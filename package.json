{
  "name": "webdriverio-ui-typescript",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "wdio run wdio.conf.ts",
    "test:smoke": "wdio run wdio.conf.ts --mochaOpts.grep @smoke",
    "test:regression": "wdio run wdio.conf.ts --mochaOpts.grep @regression",
    "test:headed": "cross-env BROWSER_HEADLESS=false wdio run wdio.conf.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src test --ext .ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "allure:generate": "allure generate allure-results -o allure-report --clean",
    "allure:open": "allure open allure-report"
  },
  "devDependencies": {
    "@wdio/cli": "8.40.6",
    "@wdio/local-runner": "8.40.6",
    "@wdio/mocha-framework": "8.40.6",
    "@wdio/spec-reporter": "8.40.6",
    "@wdio/allure-reporter": "8.40.6",
    "@wdio/types": "8.40.6",
    "allure-commandline": "2.30.0",
    "chromedriver": "latest",
    "wdio-chromedriver-service": "8.1.1",
    "cross-env": "7.0.3",
    "typescript": "5.4.5",
    "ts-node": "10.9.2",
    "@typescript-eslint/eslint-plugin": "7.14.0",
    "@typescript-eslint/parser": "7.14.0",
    "eslint": "8.57.0",
    "eslint-config-prettier": "9.1.0",
    "prettier": "3.3.0",
    "dotenv": "16.4.5"
  }
}
